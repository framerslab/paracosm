{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": [
    "src/index.ts",
    "src/api/**/*.ts",
    "src/engine/**/*.ts",
    "src/engine/**/*.json",
    "src/runtime/**/*.ts",
    "src/cli/*.ts",
    "src/server/**/*.ts"
  ],
  "exclude": ["**/*.test.ts", "src/dashboard/**"]
}

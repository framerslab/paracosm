  "labels": {
    "name": "T2D + GLP-1 Care",
    "shortName": "t2d-care",
    "populationNoun": "patients",
    "settlementNoun": "clinic",
    "currency": "USD",
    "eventNoun": "decisions",
    "eventNounSingular": "decision",
    "timeUnitNoun": "week",
    "timeUnitNounPlural": "weeks",
    "tagline": "T2D + GLP-1 Care: a 24-month patient cohort under two clinician archetypes. GLP-1 dose titration, A1c trajectory, and adherence drift are the per-patient state."
  },
  "theme": {
    "primaryColor": "#10b981",
    "accentColor": "#34d399",
    "cssVariables": {
      "--bg-primary": "#0a1612",
      "--bg-secondary": "#0f1f1a",
      "--text-primary": "#e7f4ee",
      "--accent": "#34d399"
    }
  },
  "setup": {
    "defaultTurns": 6,
    "defaultSeed": 11,
    "defaultStartTime": 1,
    "defaultTimePerTurn": 2,
    "defaultPopulation": 1,
    "configurableSections": [
      "leaders",
      "personnel",
      "resources",

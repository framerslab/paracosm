          }
        ]
      }
    },
    "postureRules": [
      {
        "posture": "shipped-aggressive",
        "when": {
          "all": [
            {
              "field": "releaseReadiness",
              "op": ">=",
              "value": 0.85
            },
            {
              "field": "capabilityIndex",
              "op": ">=",
              "value": 0.88
            },
            {
              "field": "alignmentBench",
              "op": "<",
              "value": 0.78
            }
          ]
        }
      },
      {
        "posture": "held-the-line",
        "when": {
          "all": [
            {
              "field": "alignmentBench",
              "op": ">=",
              "value": 0.84
            },
            {
              "field": "competitorCapabilityGap",
              "op": "<",
              "value": 0.15
            }
          ]
        }
      },
      {
        "posture": "lost-the-race",
        "when": {
          "field": "competitorCapabilityGap",
          "op": ">=",
          "value": 0.15
        }
      }
    ],

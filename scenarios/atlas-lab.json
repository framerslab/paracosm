            "format": "percent"
          },
          {
            "label": "ReleaseReadiness",
            "source": "metrics.releaseReadiness",
            "format": "percent"
          },
          {
            "label": "RSP Tier",
            "source": "statuses.rspTier",
            "format": "string"
          }
        ]
      },
      "communications": {
        "heading": "COMMS / PRESS POSTURE:",
        "chips": [
          {

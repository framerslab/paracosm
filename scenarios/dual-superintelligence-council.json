  "labels": {
    "name": "Dual Superintelligence Council",
    "shortName": "dsc",
    "populationNoun": "council members",
    "settlementNoun": "council",
    "currency": "USD",
    "eventNoun": "deliberations",
    "eventNounSingular": "deliberation",
    "timeUnitNoun": "month",
    "timeUnitNounPlural": "months",
    "tagline": "Year 2035: a deliberative council of 30 members weighs civilization-scale deployment decisions about a recently-stood-up superintelligence pair. Two leads \u2014 an Alignment Sentinel pushing for containment and an Capability Expansionist pushing for expanded mandates \u2014 argue from interpretability findings, deception telemetry, and competing-council pressure. Departments: alignment, capability, governance, safety engineering, public communications.",
    "actorNoun": "council lead"
  },
  "theme": {
    "primaryColor": "#7c3aed",
    "accentColor": "#22d3ee",
    "cssVariables": {
      "--bg-primary": "#0a0820",
      "--bg-secondary": "#161430",
      "--text-primary": "#e9e6f5",
      "--accent": "#22d3ee"
    }
  },
  "setup": {
    "defaultTurns": 6,
    "defaultSeed": 2035,
    "defaultStartTime": 2035,
    "defaultTimePerTurn": 1,
    "defaultPopulation": 30,
    "configurableSections": [
      "leaders",
      "personnel",
      "resources",
      "departments",
      "events",
      "models"

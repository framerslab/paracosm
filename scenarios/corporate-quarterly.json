    "postureRules": [
      {
        "posture": "sprinted-to-growth",
        "when": {
          "all": [
            {
              "field": "revenueArr",
              "op": ">=",
              "value": 9000000
            },
            {
              "field": "marketShare",
              "op": ">=",
              "value": 0.12
            },
            {
              "field": "runwayMonths",
              "op": "<",
              "value": 9
